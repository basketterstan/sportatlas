rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin check (met exists) zoals jij vroeg
    function isAdmin() {
      return isSignedIn() && (
        isEmailAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // Admin via email (voor je shop write rules)
    function isEmailAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && (request.auth.token.email.lower() == 'daenen.stan@gmail.com' ||
            request.auth.token.email.lower() == 'contact@hoopsatlas.com' ||
            request.auth.token.email.lower() == 'test@apple.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isClubOwner() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('plan', 'free') in ['club10', 'club20', 'clubUnlimited'];
    }

    function isTeamMember(teamId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/teams/$(teamId)) &&
        (
          get(/databases/$(database)/documents/teams/$(teamId)).data.coachId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.get('memberUids', [])
        );
    }

    function isTeamCoach(teamId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/teams/$(teamId)) &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.coachId == request.auth.uid;
    }

    // ------------------------------------------------------------------
    // USERS
    // ------------------------------------------------------------------
    match /users/{userId} {
      // Gebruik isEmailAdmin om recursie in isAdmin te vermijden
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.uid == request.auth.uid;
      allow update: if (
        isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'username',
          'email',
          'photoFileName',
          'role',
          'language',
          'sport',
          'updatedAt',
          'lastActiveAt',
          'notificationsEnabled',
          'fcmToken',
          'externalVaultUrl',
          'multiCloudEnabled',
          'tshirtAddressSubmitted'
        ]) &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'isAdmin',
          'isTester',
          'isStreamer',
          'plan',
          'stripeRole',
          'subscriptionActive',
          'isSubscribed',
          'proExpiresAt',
          'earningsBalance',
          'referralCount',
          'managedCoachUids',
          'managedByUid',
          'clubId',
          'adminNotes'
        ]) == false
      ) || isEmailAdmin() || (
        isClubOwner() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['managedByUid', 'clubId', 'plan', 'subscriptionActive', 'updatedAt']) &&
        (request.resource.data.managedByUid == request.auth.uid || request.resource.data.managedByUid == null ||
         request.resource.data.clubId == request.auth.uid || request.resource.data.clubId == null)
      ) || (
        isOwner(userId) && isClubOwner() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['managedCoachUids', 'updatedAt'])
      );
      allow delete: if isEmailAdmin();

      allow list: if isSignedIn();
    }

    // ------------------------------------------------------------------
    // SHOP
    // ------------------------------------------------------------------
    match /products/{productId} {
      allow read: if true;
      // Alleen admin mag schrijven (email-admin zoals gevraagd)
      allow write: if isEmailAdmin() || isAdmin();
    }

    match /orders/{orderId} {
      // Auth user kan order aanmaken
      allow create: if isSignedIn();

      // Owner of admin kan lezen/updaten
      allow read, update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isAdmin() ||
        isEmailAdmin()
      );
    }

    // ------------------------------------------------------------------
    // DRILLS / TRAININGS (uit je laatste snippet)
    // ------------------------------------------------------------------
    match /drills/{drillId} {
      allow read: if true;
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && ((resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /trainings/{trainingId} {
      allow read: if true;
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && ((resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ------------------------------------------------------------------
    // SIGNALS / FEEDBACK / REQUESTS
    // ------------------------------------------------------------------
    match /partner_signals/{signalId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }

    match /checkout_signals/{signalId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }

    match /onboarding_signals/{signalId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }

    match /feedback/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /partner_applications/{id} {
      allow create: if true;
      allow read: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow write: if isAdmin();
      allow list: if isAdmin();
    }

    match /cancellation_requests/{id} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    match /film_requests/{id} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // CONFIG / QUEUES
    // ------------------------------------------------------------------
    match /system_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /push_queue/{id} {
      allow read, write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // MESSAGES (subcollection op eender welk pad)
    // ------------------------------------------------------------------
    match /squadMessages/{messageId} {
      allow read: if isTeamMember(resource.data.teamId) || isAdmin();
      allow create: if isTeamMember(request.resource.data.teamId) &&
        request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.senderId == request.auth.uid);
    }

    match /{path=**}/squadMessages/{messageId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ------------------------------------------------------------------
    // TEAMS (uit je laatste snippet)
    // ------------------------------------------------------------------
    match /teams/{teamId} {
      allow read: if isAdmin() ||
        (isSignedIn() && (resource.data.coachId == request.auth.uid || request.auth.uid in resource.data.get('memberUids', [])));
      allow create: if isSignedIn() && request.resource.data.coachId == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.coachId == request.auth.uid) ||
        (
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberUids']) &&
          request.auth.uid in request.resource.data.get('memberUids', [])
        );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.coachId == request.auth.uid);
    }

    // ------------------------------------------------------------------
    // OVERIGE (uit je eerdere rules) – laat staan als je ze gebruikt
    // ------------------------------------------------------------------
    match /assignments/{assignmentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.coachId == request.auth.uid);
    }

    match /privateMessages/{msgId} {
      allow create: if isSignedIn();
      allow read, list: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    match /matches/{matchId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /referralCodes/{code} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }

    match /joinCodes/{code} {
      allow read: if true;
      allow create, delete: if isSignedIn();
    }

    match /events/{eventId} {
      allow read, list: if true;
      allow create: if isAdmin() || isTeamCoach(request.resource.data.teamId);
      allow update, delete: if isAdmin() || isTeamCoach(resource.data.teamId);
    }

    match /attendance/{attId} {
      allow read: if true;
      allow create: if isAdmin() ||
        (
          isTeamMember(request.resource.data.teamId) &&
          request.resource.data.userId == request.auth.uid
        ) ||
        (
          request.resource.data.keys().hasAll(['parentToken']) &&
          exists(/databases/$(database)/documents/parentInvites/$(request.resource.data.parentToken)) &&
          get(/databases/$(database)/documents/parentInvites/$(request.resource.data.parentToken)).data.teamId == request.resource.data.teamId
        );
      allow update: if isAdmin() ||
        (
          isTeamMember(resource.data.teamId) &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid
        ) ||
        (
          resource.data.keys().hasAll(['parentToken']) &&
          request.resource.data.keys().hasAll(['parentToken']) &&
          resource.data.parentToken == request.resource.data.parentToken &&
          exists(/databases/$(database)/documents/parentInvites/$(request.resource.data.parentToken)) &&
          get(/databases/$(database)/documents/parentInvites/$(request.resource.data.parentToken)).data.teamId == request.resource.data.teamId
        );
      allow delete: if isAdmin() || isTeamCoach(resource.data.teamId);
    }

    match /parentInvites/{token} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.coachId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.coachId == request.auth.uid);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /courts/{courtId} {
      allow read, list, create: if isSignedIn();
    }

    match /liveMatches/{matchId} {
      allow read, list: if true;
      allow create: if isSignedIn() &&
        (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.streamerId == request.auth.uid
        );
      allow update, delete: if isAdmin() ||
        (
          isSignedIn() &&
          (
            (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) ||
            (resource.data.streamerId == request.auth.uid && request.resource.data.streamerId == request.auth.uid)
          )
        );
    }

    match /visionAnalyses/{id} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /playerProfiles/{profileId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /matchStats/{matchId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /public_tournaments/{tourneyId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ------------------------------------------------------------------
    // SCRIMMAGE HUB
    // ------------------------------------------------------------------
    match /scrimmages/{scrimmageId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);

      match /messages/{messageId} {
        allow read, list: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }

    // ------------------------------------------------------------------
    // COACH HUB — COMMUNITY
    // ------------------------------------------------------------------
    match /communityPosts/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /communityReplies/{replyId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /channelMessages/{msgId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    // Subcollections voor likes & saves
    match /users/{userId}/postLikes/{postId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/savedPosts/{postId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/replyLikes/{replyId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------
    // T-SHIRT CLAIMS — July 2026 promo
    // ------------------------------------------------------------------
    match /tshirt_claims/{claimId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, list: if isAdmin();
    }

    match /customers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      match /checkout_sessions/{id} { allow read, write: if request.auth.uid == uid; }
      match /subscriptions/{id} { allow read: if request.auth.uid == uid; }
      match /payments/{id} { allow read: if request.auth.uid == uid; }
      match /portal_sessions/{id} { allow read, write: if request.auth.uid == uid; }
    }

    // default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
